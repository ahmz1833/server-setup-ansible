#!/bin/bash
# Update ipset: {{ item.name }}
set -euo pipefail

NAME="{{ item.name }}"
URL="{{ item.url }}"
TYPE="{{ item.type | default('hash:net') }}"
FAMILY="{{ item.family | default('inet') }}"
DIR="{{ core_ipset_data_dir }}"

TEMP=$(mktemp)
trap "rm -f $TEMP" EXIT

curl -sSfL --max-time 120 "$URL" -o "$TEMP" || exit 1

{% if item.family | default('inet') == 'inet6' %}
PATTERN='^[0-9a-fA-F:]+(/[0-9]+)?$'
{% else %}
PATTERN='^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$'
{% endif %}

ipset create "${NAME}_tmp" "$TYPE" family "$FAMILY" -exist
ipset flush "${NAME}_tmp"

grep -E "$PATTERN" "$TEMP" | while read -r ip; do
  ipset add "${NAME}_tmp" "$ip" -exist 2>/dev/null || true
done

ipset swap "${NAME}_tmp" "$NAME"
ipset destroy "${NAME}_tmp"
ipset save "$NAME" > "${DIR}/${NAME}.save"
