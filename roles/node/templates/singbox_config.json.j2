{# ================================== DNS SERVER MACRO ================================== #}
{% macro dns_server(server_config, tag, detour=None) -%}
{%- set result = {'tag': tag} -%}
{%- if server_config == 'local' -%}
{%- set _ = result.update({'type': 'local'}) -%}
{%- elif server_config.startswith('tls://') -%}
{%- set _ = result.update({'type': 'tls', 'server': server_config[6:]}) -%}
{%- elif server_config.startswith('https://') -%}
{%- set url_part = server_config[8:] -%}
{%- set server = url_part.split('/')[0] -%}
{%- set path = '/' + '/'.join(url_part.split('/')[1:]) if '/' in url_part else '/dns-query' -%}
{%- set _ = result.update({'type': 'https', 'server': server, 'path': path}) -%}
{%- elif server_config.startswith('quic://') -%}
{%- set _ = result.update({'type': 'quic', 'server': server_config[7:]}) -%}
{%- else -%}
{%- set _ = result.update({'type': 'udp', 'server': server_config}) -%}
{%- endif -%}
{%- if detour and detour != 'direct' -%}
{%- set _ = result.update({'detour': detour}) -%}
{%- endif -%}
{{ result | to_json }}
{%- endmacro %}
{# =================================== DNS RULE MACRO =================================== #}
{% macro dns_rule(rule) -%}
{%- set result = {} -%}
{%- set _ = result.update(rule) -%}
{%- if result.server is defined and result.server != 'block' and not result.server.startswith('dns-') -%}
{%- set _ = result.update({'server': 'dns-' ~ result.server}) -%}
{%- endif -%}
{{ result | to_json }}
{%- endmacro %}
{# =================================== COMPUTED VALUES ================================== #}
{%- set dns = node_singbox_dns | default({}) -%}
{%- set dns_fakeip = dns.get('fakeip', true) -%}
{%- set dns_strategy = dns.get('strategy', 'ipv4_only') -%}
{%- set dns_rules = dns.get('rules', []) + node_singbox_dns_default_rules | default([]) -%}
{%- set outbounds = node_singbox_outbounds | default({}) -%}
{%- set direct_rulesets = node_singbox_direct_rulesets | default([]) -%}
{%- set direct_domain_suffix = node_singbox_direct_domain_suffix | default([]) -%}
{%- set direct_ip_cidr = node_singbox_direct_ip_cidr | default([]) -%}
{# ================================= MAIN CONFIGURATION ================================= #}
{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {{ dns_server(dns.get('remote', 'tls://8.8.8.8'), 'dns-remote', node_singbox_final_outbound) }},
      {{ dns_server(dns.get('direct', 'local'), 'dns-direct', 'direct') }},
{% if dns_fakeip %}
      {
        "tag": "dns-fake",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
{% if node_enable_ipv6 %},
        "inet6_range": "fc00::/18"
{% endif %}
      },
{% endif %}
      {
        "tag": "dns-local",
        "type": "local"
      }
    ],
    "rules": [
{% if not node_enable_ipv6 %}
      {
        "query_type": ["AAAA"],
        "action": "predefined",
        "rcode": "REFUSED"
      },
{% endif %}
{% for rule in dns_rules %}
      {{ dns_rule(rule) }}{% if not loop.last or dns_fakeip %},{% endif %}

{% endfor %}
{% if dns_fakeip %}
      {
        "query_type": ["A"{% if node_enable_ipv6 %}, "AAAA"{% endif %}],
        "action": "route",
        "server": "dns-fake"
      }
{% endif %}
    ],
    "strategy": "{{ dns_strategy }}",
    "independent_cache": true
  },
  "inbounds": [
    {
      "tag": "mixed-in",
      "type": "mixed",
      "listen": "{{ node_singbox_mixed_listen }}",
      "listen_port": {{ node_singbox_mixed_port }}
    }
{%- if node_singbox_tun_enabled %},
    {
      "tag": "tun-in",
      "type": "tun",
      "interface_name": "{{ node_singbox_tun_interface }}",
      "stack": "{{ node_singbox_tun_stack }}",
      "mtu": {{ node_singbox_tun_mtu }},
      "auto_redirect": {{ node_singbox_tun_auto_redirect | to_json }},
      "auto_route": {{ node_singbox_tun_auto_route | to_json }},
      "strict_route": {{ node_singbox_tun_strict_route | to_json }},
      "address": ["{{ node_singbox_tun_inet4_address }}"{% if node_enable_ipv6 %},"{{ node_singbox_tun_inet6_address }}"{% endif %}]
{%- if direct_rulesets | length > 0 %},
      "route_exclude_address_set": [{% for rs in direct_rulesets %}"{{ rs.tag }}"{% if not loop.last %}, {% endif %}{% endfor %}]
{%- endif %}
    }
{% endif %}
  ],
  "outbounds": [
{% for cfg in outbounds.configs | default([]) %}
    {{ cfg | to_json }},
{% endfor %}
{% for proxy in node_singbox_dynamic_proxies | default([]) %}
    {{ proxy | to_json }},
{% endfor %}
{% for selector in outbounds.selectors | default([]) %}
{%- set sel = selector.copy() -%}
{%- set use_all_links = sel.pop('use_all_links', false) -%}
{%- if use_all_links and node_singbox_dynamic_proxies is defined -%}
  {%- set dynamic_tags = node_singbox_dynamic_proxies | map(attribute='tag') | list -%}
  {%- set _ = sel.update({'outbounds': (sel.get('outbounds', []) + dynamic_tags) | unique }) -%}
{%- endif %}
    {{ sel | to_json }},
{% endfor %}
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "block",
      "type": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "action": "sniff",
        "inbound": ["mixed-in"{% if node_singbox_tun_enabled %}, "tun-in"{% endif %}]
      },
      {
        "action": "hijack-dns",
        "protocol": "dns"
      },
      {
        "action": "route",
        "ip_is_private": true,
        "outbound": "direct"
      }
{%- if direct_rulesets | length > 0 or direct_domain_suffix | length > 0 or direct_ip_cidr | length > 0 %},
      {
        "action": "route",
{% if direct_rulesets | length > 0 %}
        "rule_set": [{% for rs in direct_rulesets %}"{{ rs.tag }}"{% if not loop.last %}, {% endif %}{% endfor %}],
{% endif %}{% if direct_domain_suffix | length > 0 %}
        "domain_suffix": {{ direct_domain_suffix | to_json }},
{% endif %}{%- if direct_ip_cidr | length > 0 %}
        "ip_cidr": {{ direct_ip_cidr | to_json }},
{% endif %}
        "outbound": "direct"
      }
{% endif %}
    ],
{% if direct_rulesets | length > 0 %}
    "rule_set": [
{% for rs in direct_rulesets %}
      {
        "tag": "{{ rs.tag }}",
        "type": "remote",
        "format": "{{ rs.format | default('binary') }}",
        "url": "{{ rs.url }}",
        "download_detour": "{{ rs.download_detour | default('direct') }}"
      }{% if not loop.last %},{% endif %}

{% endfor %}
    ],
{% endif %}
    "final": "{{ node_singbox_final_outbound }}",
    "find_process": true,
    "auto_detect_interface": true,
    "default_domain_resolver": "dns-direct"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    }
  }
}
