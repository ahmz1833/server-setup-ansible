{# ===================================== Macros ===================================== #}
{# ------------------------------- Security Headers --------------------------------- #}
{% macro security_headers(site, is_ssl=false) -%}
{% set opt_x_frame = site.header_x_frame_options | default(nginx_header_x_frame_options) %}
{% set opt_x_cto = site.header_x_content_type_options | default(nginx_header_x_content_type_options) %}
{% set opt_x_xss = site.header_x_xss_protection | default(nginx_header_x_xss_protection) %}
{% set opt_ref_pol = site.header_referrer_policy | default(nginx_header_referrer_policy) %}
{% set opt_perm_pol = site.header_permissions_policy | default(nginx_header_permissions_policy) %}
{% set opt_csp = site.header_csp | default(nginx_header_csp) %}
{% set opt_hsts = site.header_hsts | default(nginx_header_hsts) %}
{% set opt_cache = site.cache_control | default(nginx_header_cache_control) %}
{% if opt_x_frame %}
    add_header X-Frame-Options "{{ opt_x_frame }}" always;
{% endif %}
{% if opt_x_cto %}
    add_header X-Content-Type-Options "{{ opt_x_cto }}" always;
{% endif %}
{% if opt_x_xss %}
    add_header X-XSS-Protection "{{ opt_x_xss }}" always;
{% endif %}
{% if opt_ref_pol %}
    add_header Referrer-Policy "{{ opt_ref_pol }}" always;
{% endif %}
{% if opt_perm_pol %}
    add_header Permissions-Policy "{{ opt_perm_pol }}" always;
{% endif %}
{% if opt_csp %}
    add_header Content-Security-Policy "{{ opt_csp }}" always;
{% endif %}
{% if is_ssl and opt_hsts %}
    add_header Strict-Transport-Security "{{ opt_hsts }}" always;
{% endif %}
{% if opt_cache %}
    add_header Cache-Control "{{ opt_cache }}";
{% endif %}
{% if nginx_show_cache_status | default(false) %}
    add_header X-Cache-Status $upstream_cache_status;
{% endif %}
{%- endmacro %}
{# ------------------------------ WAF Configuration --------------------------------- #}
{% macro waf_config(site) -%}
{% if site.waf_enabled | default(false) %}
    modsecurity on;
{% if site.waf_config is defined or site.waf_extra_rules is defined %}
    modsecurity_rules '
        Include /etc/modsecurity/modsecurity.conf
{% for k, v in (site.waf_config | default({})).items() %}
        {{ k }} {{ v }}
{% endfor %}
        Include /etc/modsecurity/crs-setup.conf
        Include /usr/share/modsecurity-crs/rules/*.conf
{{ site.waf_extra_rules | default('') | indent(8, true) }}
    ';
{% else %}
    modsecurity_rules_file /etc/nginx/modsec/main.conf;
{% endif %}
{% endif %}
{%- endmacro %}
{# --------------------------- Proxy Pass Configuration ----------------------------- #}
{% macro proxy_pass(upstream, site, location=none) -%}
{% set intercept = location.proxy_intercept_errors | default(site.proxy_intercept_errors | default(nginx_proxy_intercept_errors)) if location else site.proxy_intercept_errors | default(nginx_proxy_intercept_errors) %}
{% set timeout_connect = site.proxy_connect_timeout | default(nginx_proxy_connect_timeout) %}
{% set timeout_send = site.proxy_send_timeout | default(nginx_proxy_send_timeout) %}
{% set timeout_read = site.proxy_read_timeout | default(nginx_proxy_read_timeout) %}
        proxy_pass {{ upstream }};
        proxy_http_version 1.1;
        proxy_intercept_errors {{ intercept }};
        proxy_connect_timeout {{ timeout_connect }};
        proxy_send_timeout {{ timeout_send }};
        proxy_read_timeout {{ timeout_read }};
        proxy_buffering {{ site.proxy_buffering | default(nginx_proxy_buffering) }};
        proxy_buffer_size {{ site.proxy_buffer_size | default(nginx_proxy_buffer_size) }};
        proxy_buffers {{ site.proxy_buffers | default(nginx_proxy_buffers) }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
{%- endmacro %}
{# ---------------------------------- Rate Limiting --------------------------------- #}
{% macro rate_limit_config(loc) -%}
{% if loc.rate_limit is defined %}
{% set zone = loc.rate_limit.zone | default(nginx_rate_limit_zone_name) %}
{% set burst = loc.rate_limit.burst | default(nginx_rate_limit_burst) %}
{% set nodelay = loc.rate_limit.nodelay | default(nginx_rate_limit_nodelay) %}
        limit_req zone={{ zone }} burst={{ burst }}{% if nodelay %} nodelay{% endif %};
{% endif %}
{%- endmacro %}
{# ---------------------------- Error Pages Configuration --------------------------- #}
{% macro error_pages(site, site_custom_codes, fallback_codes) -%}
    # Error Pages Configuration
{% for code in site_custom_codes %}
    error_page {{ code }} /site_errors/{{ code }}.html;
{% endfor %}
{% for code in fallback_codes %}
    error_page {{ code }} /global_errors/{{ code }}.html;
{% endfor %}

{% if site_custom_codes | length > 0 %}
    location /site_errors/ {
        internal;
        alias /var/www/nginx/errors/{{ site.domain }}/;
    }
{% endif %}
    location /global_errors/ {
        internal;
        alias /var/www/nginx/errors/global/;
    }
{%- endmacro %}
{# -------------------------------- Location Block ---------------------------------- #}
{% macro location_block(loc, site, is_ssl=false) -%}
    location {{ loc.path }} {
        set $endpoint_name "{{ loc.path }}";

{% if loc.log_prefix is defined %}
        access_log /var/log/nginx/{{ site.domain }}_{{ loc.log_prefix }}_access.log json_analytics;
        error_log /var/log/nginx/{{ site.domain }}_{{ loc.log_prefix }}_error.log warn;
{% endif %}

{{ rate_limit_config(loc) }}

{% if loc.upstream is defined %}
{{ proxy_pass(loc.upstream, site, loc) }}
{% endif %}

{% if loc.cache_control is defined %}
{{ security_headers(site, is_ssl) | indent(8) }}
        add_header Cache-Control "{{ loc.cache_control }}";
{% endif %}

{% for k, v in (loc.nginx_config | default({})).items() %}
        {{ k }} {{ v }};
{% endfor %}

        {{ loc.extra_config | default('') | indent(8) }}
    }
{%- endmacro %}
{# -------------------------------- SSL Configuration ------------------------------- #}
{% macro ssl_config(site) -%}
    ssl_certificate {{ site.ssl_cert | default(nginx_ssl_cert_dir ~ '/' ~ site.domain ~ '/fullchain.pem') }};
    ssl_certificate_key {{ site.ssl_key | default(nginx_ssl_cert_dir ~ '/' ~ site.domain ~ '/privkey.pem') }};
    ssl_protocols {{ site.ssl_protocols | default(nginx_ssl_protocols) }};
    ssl_prefer_server_ciphers {{ site.ssl_prefer_server_ciphers | default(nginx_ssl_prefer_server_ciphers) }};
    ssl_ciphers '{{ site.ssl_ciphers | default(nginx_ssl_ciphers) }}';
    ssl_session_cache {{ site.ssl_session_cache | default(nginx_ssl_session_cache) }};
    ssl_session_timeout {{ site.ssl_session_timeout | default(nginx_ssl_session_timeout) }};
    ssl_session_tickets {{ site.ssl_session_tickets | default(nginx_ssl_session_tickets) }};
{% if site.ssl_stapling | default(nginx_ssl_stapling) %}
    ssl_stapling on;
    ssl_stapling_verify {{ 'on' if (site.ssl_stapling_verify | default(nginx_ssl_stapling_verify)) else 'off' }};
{% if site.ssl_trusted_certificate | default(nginx_ssl_trusted_certificate) %}
    ssl_trusted_certificate {{ site.ssl_trusted_certificate | default(nginx_ssl_trusted_certificate) }};
{% endif %}
{% endif %}
{%- endmacro %}
{# --------------------------- ACME Webroot Configuration ------------------------- #}
{% macro acme_challenge(site) -%}
{% if site.acme_challenge_enabled | default(nginx_acme_challenge_enabled) %}
    location ^~ /.well-known/acme-challenge/ {
        allow all;
        root {{ nginx_default_acme_dir }};
        default_type "text/plain";
        access_log off;
    }
{% endif %}
{%- endmacro %}
{# -------------------- Full Server Block Content (non-redirect) -------------------- #}
{% macro server_content(site, site_custom_codes, fallback_codes, is_ssl=false) -%}
{{ security_headers(site, is_ssl) }}

{{ waf_config(site) }}

{% for k, v in (site.nginx_config | default({})).items() %}
    {{ k }} {{ v }};
{% endfor %}

    {{ site.extra_config | default('') | indent(4) }}

{{ error_pages(site, site_custom_codes, fallback_codes) }}

{{ acme_challenge(site) }}

{% if site.upstream is defined %}
    location / {
        set $endpoint_name "/";
{{ proxy_pass(site.upstream, site) }}
    }
{% endif %}

{% for loc in site.locations | default([]) %}
{{ location_block(loc, site, is_ssl) }}
{% endfor %}
{%- endmacro %}
{# ------------------------------ Complete Server Block ----------------------------- #}
{% macro server_block(site, port, ssl=false, redirect_only=false, site_custom_codes=[], fallback_codes=[]) -%}
server {
{% if ssl %}
    listen {{ port }} ssl http2;
{% if nginx_enable_ipv6 | default(false) %}
    listen [::]:{{ port }} ssl http2;
{% endif %}
{% else %}
    listen {{ port }};
{% if nginx_enable_ipv6 | default(false) %}
    listen [::]:{{ port }};
{% endif %}
{% endif %}
    server_name {{ site.domain }}{% if site.aliases is defined %} {{ site.aliases | join(' ') }}{% endif %};
    server_tokens {{ site.server_tokens | default(nginx_server_tokens) }};

{% if ssl %}
{{ ssl_config(site) }}

{% endif %}
{% if redirect_only %}
    set $endpoint_name "redirect";

{{ acme_challenge(site) }}

    location / {
{% if site.redirect_to is defined %}
        return 301 {{ site.redirect_to }}$request_uri;
{% else %}
        return 301 https://$host$request_uri;
{% endif %}
    }
{% else %}
    set $endpoint_name "{% if site.redirect_to is defined %}redirect{% else %}root{% endif %}";

    access_log /var/log/nginx/{{ site.domain }}_access.log json_analytics;
    error_log /var/log/nginx/{{ site.domain }}_error.log warn;

{% if site.redirect_to is defined %}
    location / {
        return 301 {{ site.redirect_to }}$request_uri;
    }
{% else %}
{{ server_content(site, site_custom_codes, fallback_codes, ssl) }}
{% endif %}
{% endif %}
}
{%- endmacro %}
{# ============================== Main Template Logic =============================== #}
{# Calculate error codes once #}
{% set site_custom_codes = [] %}
{% if item.custom_errors is defined %}
{% for cerr in item.custom_errors %}
{% set matched_codes = nginx_standard_error_codes.keys() | map('string') | select('match', cerr.match) | list %}
{% for code in matched_codes %}
{% if code not in site_custom_codes %}
{% set _ = site_custom_codes.append(code) %}
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
{% set fallback_codes = [] %}
{% for code in nginx_standard_error_codes.keys() | map('string') %}
{% if code not in site_custom_codes %}
{% set _ = fallback_codes.append(code) %}
{% endif %}
{% endfor %}
{# Generate server blocks #}
{% if item.ssl_enabled | default(false) %}
{# HTTP redirect server #}
{{ server_block(item, 80, ssl=false, redirect_only=true) }}

{# HTTPS main server #}
{{ server_block(item, 443, ssl=true, redirect_only=false, site_custom_codes=site_custom_codes, fallback_codes=fallback_codes) }}
{% else %}
{# HTTP-only server #}
{{ server_block(item, 80, ssl=false, redirect_only=false, site_custom_codes=site_custom_codes, fallback_codes=fallback_codes) }}
{% endif %}
