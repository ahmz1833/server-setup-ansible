server {
    listen 127.0.0.1:{{ nginx_dummy_metric_port }};
    server_name 127.0.0.1;

    location /metrics {
        stub_status on;
        access_log off;
        allow 127.0.0.1;
        deny all;
    }

    # Blackhole for Promtail when Loki is not configured.
    # This local 204 fallback is an intentional operational safeguard,
    # allowing the Promtail metrics pipeline to function perfectly 
    # (parsing logs into Prometheus metrics) without crashing or 
    # flooding error logs when a remote Loki URL isn't present.
    location /loki/api/v1/push {
        access_log off;
        return 204;
    }
}
